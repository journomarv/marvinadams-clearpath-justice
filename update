    <div style={{ marginBottom: 14 }}>
      <div style={{ fontSize: 11.5, color: T.inkSoft, marginBottom: 3, fontFamily: "'IBM Plex Mono', monospace" }}>{label}</div>
      <div style={{ fontSize: 14, fontWeight: value ? 600 : 400, color: value ? T.ink : T.inkSoft, fontStyle: value ? "normal" : "italic" }}>
        {value || "pending"}
      </div>
    </div>
  );
}

function ResultCertificate({ result, onRestart }) {
  const { Icon } = result;
  return (
    <div className="cpp-rise" style={{ ...cardBase, padding: "36px 32px", position: "relative", overflow: "hidden" }}>
      <div
        className="cpp-stamp"
        style={{
          display: "inline-flex", alignItems: "center", gap: 8, border: `2px solid ${result.color}`,
          color: result.color, borderRadius: 3, padding: "6px 14px", fontFamily: "'IBM Plex Mono', monospace",
          fontSize: 12.5, fontWeight: 600, letterSpacing: "0.08em", transform: "rotate(-7deg)", marginBottom: 22,
        }}
      >
        <Icon size={15} strokeWidth={2.2} />
        {result.stampLabel}
      </div>

      <h2 style={{ fontFamily: "'Lora', serif", fontSize: 26, fontWeight: 600, margin: "0 0 8px", color: T.ink }}>
        {result.title}
      </h2>

      {result.citation && (
        <div style={{ fontFamily: "'IBM Plex Mono', monospace", fontSize: 12.5, color: result.color, marginBottom: 18 }}>
          {result.citation}
        </div>
      )}

      <p style={{ fontSize: 15, lineHeight: 1.65, color: T.ink, maxWidth: 620, margin: result.citation ? 0 : "0 0 18px" }}>
        {result.body}
      </p>

      <div style={{ marginTop: 22, background: result.soft, borderRadius: 3, padding: "16px 18px", maxWidth: 620 }}>
        <div style={{ fontSize: 11.5, fontWeight: 600, letterSpacing: "0.06em", color: result.color, marginBottom: 6 }}>
          WHAT HAPPENS NEXT
        </div>
        <p style={{ fontSize: 14, lineHeight: 1.6, color: T.ink, margin: 0 }}>{result.next}</p>
      </div>

      {result.caution && (
        <div style={{ marginTop: 14, borderLeft: `2px solid ${T.paperLine}`, paddingLeft: 14, maxWidth: 620 }}>
          <p style={{ fontSize: 12.5, lineHeight: 1.6, color: T.inkSoft, margin: 0, fontStyle: "italic" }}>
            {result.caution}
          </p>
        </div>
      )}

      <button className="cpp-btn" style={{ marginTop: 26, background: T.ink, color: "#fff" }} onClick={onRestart}>
        <RotateCcw size={14} /> Check another record
      </button>
    </div>
  );
}

function CheckerPage() {
  const [step, setStep] = useState(0);
  const [legalBasis, setLegalBasis] = useState(null);
  const [offence, setOffence] = useState(null);

  const restart = () => {
    setStep(0);
    setLegalBasis(null);
    setOffence(null);
  };

  const result = step === 2 ? resultFor(offence, legalBasis) : null;

  return (
    <div className="cpp-shell" style={{ padding: "56px 24px 20px" }}>
      <Eyebrow>CANNABIS FOR PRIVATE PURPOSES ACT 7 OF 2024 &middot; SECTION 5</Eyebrow>
      <h1 style={{ fontFamily: "'Lora', serif", fontWeight: 600, fontSize: "clamp(28px, 4vw, 38px)", lineHeight: 1.15, margin: "0 0 10px", color: T.ink }}>
        Check your expungement status
      </h1>
      <p style={{ color: T.inkSoft, fontSize: 15, maxWidth: 560, lineHeight: 1.6, margin: "0 0 24px" }}>
        Answer two questions about your conviction. We'll tell you which part of the law applies
        to you — automatic, application-required, or not covered.
      </p>

      <div
        style={{
          ...cardBase,
          background: T.goldSoft,
          borderLeft: `3px solid ${T.gold}`,
          padding: "14px 18px",
          marginBottom: 32,
          maxWidth: 620,
        }}
      >
        <p style={{ fontSize: 13, lineHeight: 1.6, color: T.ink, margin: 0 }}>
          <strong>Section 5 has not yet commenced.</strong> The Act was signed in May 2024 but only
          takes effect on a date the President still has to proclaim, and regulations are still in
          draft. The result below shows what will apply once the Act is in force — it does not
          mean automatic expungement is happening today.
        </p>
      </div>

      {step < 2 && (
        <div className="cpp-grid">
          <div style={{ ...cardBase, padding: "28px 28px 24px" }} className="cpp-rise" key={step}>
            <div style={{ fontFamily: "'IBM Plex Mono', monospace", fontSize: 12, color: T.inkSoft, marginBottom: 6 }}>
              STEP {step + 1} OF 2
            </div>
            <h2 style={{ fontFamily: "'Lora', serif", fontSize: 21, fontWeight: 600, margin: "0 0 18px", color: T.ink }}>
              {step === 0 ? "Which law were you convicted under?" : "What was the conviction for?"}
            </h2>

            <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
              {(step === 0 ? LEGAL_BASIS_OPTIONS : OFFENCE_OPTIONS).map((opt) => (
                <button
                  key={opt.id}
                  className="cpp-option"
                  onClick={() => {
                    if (step === 0) {
                      setLegalBasis(opt.id);
                      setStep(1);
                    } else {
                      setOffence(opt.id);
                      setStep(2);
                    }
                  }}
                >
                  <div style={{ fontWeight: 600, fontSize: 14.5, color: T.ink, marginBottom: 3 }}>{opt.label}</div>
                  <div style={{ fontSize: 13, color: T.inkSoft, lineHeight: 1.5 }}>{opt.helper}</div>
                </button>
              ))}
            </div>

            {step === 1 && (
              <button
                className="cpp-btn"
                style={{ marginTop: 20, background: "transparent", color: T.inkSoft, border: `1px solid ${T.paperLine}` }}
                onClick={() => setStep(0)}
              >
                <ArrowLeft size={14} /> Back
              </button>
            )}
          </div>

          <div style={{ ...cardBase, borderStyle: "dashed", padding: "24px 24px", background: "#FBF9F3" }}>
            <div
              style={{
                fontFamily: "'IBM Plex Mono', monospace", fontSize: 11, letterSpacing: "0.08em",
                color: T.inkSoft, marginBottom: 16, borderBottom: `1px solid ${T.paperLine}`, paddingBottom: 10,
              }}
            >
              CASE RECORD
            </div>
            <RecordRow label="Legal basis" value={legalBasis ? LEGAL_BASIS_OPTIONS.find((o) => o.id === legalBasis)?.label : null} />
            <RecordRow label="Nature of offence" value={offence ? OFFENCE_OPTIONS.find((o) => o.id === offence)?.label : null} />
          </div>
        </div>
      )}

      {step === 2 && result && <ResultCertificate result={result} onRestart={restart} />}
    </div>
  );
}

