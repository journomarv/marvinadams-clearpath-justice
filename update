/* ---------------------------------------------------------------
   ELIGIBILITY CHECKER (from previous build)
--------------------------------------------------------------- */
const LEGAL_BASIS_OPTIONS = [
  { id: "1971", label: "Abuse of Dependence-producing Substances Act (1971)", helper: "An older law, mostly used for convictions before the 1990s." },
  { id: "1992", label: "Drugs and Drug Trafficking Act (1992)", helper: "The most common law cited in cannabis convictions in South Africa." },
  { id: "homeland", label: "A former homeland law, before 1993", helper: "Transkei, Bophuthatswana, Ciskei, Venda, or another former self-governing territory." },
  { id: "other", label: "A different law", helper: "For example, the Medicines Act or a municipal by-law. Section 5 doesn't name this law directly, so we can't classify it automatically." },
  { id: "unsure", label: "I'm not sure", helper: "That's fine — it won't change your result." },
];

const OFFENCE_OPTIONS = [
  { id: "possession", label: "Use or possession", helper: "You were found with cannabis, or using it — not selling or supplying it." },
  { id: "presumption", label: "Dealing, based on a legal presumption", helper: "You were convicted of dealing because the law presumed intent to deal — for example, from the amount found — not because dealing was proven directly." },
  { id: "proven", label: "Dealing, proven directly", helper: "The court had direct evidence that you sold or supplied cannabis." },
  { id: "childdiversion", label: "A diversion order I received as a child", helper: "Not a conviction — a record from the Child Justice Act process for using, possessing, cultivating, or dealing in cannabis as a minor." },
  { id: "unsure", label: "I'm not sure", helper: "We'll point you to where you can check your court record." },
];

function citationFor(offence, basis) {
  const idx = { "1971": "i", "1992": "ii", homeland: "iii" }[basis] || null;
  if (offence === "possession") return idx ? `s.5(1)(a)(${idx})` : "s.5(1)(a)";
  if (offence === "presumption") return idx ? `s.5(2)(a)(${idx})` : "s.5(2)(a)";
  if (offence === "childdiversion") return "s.5(2)(d)";
  return null;
}

function resultFor(offence, basis) {
  // A legal basis outside the Act's named laws can't be classified automatically,
  // regardless of what the offence was — surface that uncertainty rather than guessing.
  if (basis === "other" && (offence === "possession" || offence === "presumption")) {
    return {
      stampLabel: "NEEDS RECORD CHECK",
      title: "We can't classify this automatically",
      citation: null,
      color: T.inkSoft,
      soft: "#ECEAE3",
      Icon: HelpCircle,
      body: "Section 5 names specific laws — the 1971 Abuse of Dependence-producing Substances Act, the 1992 Drugs and Drug Trafficking Act, and pre-1993 homeland laws. A conviction under a different law (for example, the Medicines Act or a municipal by-law) isn't automatically covered, but that doesn't necessarily mean it's excluded either.",
      next: "Bring your charge sheet or the law cited on your record to a community advice office, Legal Aid SA, or an attorney so they can confirm whether it falls within section 5 or another form of relief.",
    };
  }

  if (offence === "possession") {
    return {
      stampLabel: "AUTOMATIC",
      title: "Automatic expungement applies",
      citation: citationFor(offence, basis),
      color: T.teal,
      soft: T.tealSoft,
      Icon: FileCheck2,
      body: "Convictions for use or possession of cannabis must be expunged automatically by the SAPS Criminal Record Centre — no application is required under section 5(1)(a).",
      next: "If it hasn't been expunged yet, you can make a written application to the Director-General: Justice and Constitutional Development under section 5(1)(b), and a certificate of expungement will be issued.",
    };
  }
  if (offence === "presumption") {
    return {
      stampLabel: "APPLICATION REQUIRED",
      title: "You can apply for expungement",
      citation: citationFor(offence, basis),
      color: T.gold,
      soft: T.goldSoft,
      Icon: FileClock,
      body: "Dealing convictions based on a legal presumption — rather than direct proof — qualify for expungement under section 5(2), but only once a written application is submitted.",
      next: "Submit a written application to the Director-General. If satisfied that the conviction rested on a presumption of dealing, the Director-General will issue a certificate of expungement, which is then sent to the SAPS Criminal Record Centre.",
      caution: "Note: if the Director-General later finds an applicant didn't qualify, the certificate can be revoked — but only after written notice and a 90-day opportunity to respond with reasons (s.5(4)–(5)).",
    };
  }
  if (offence === "proven") {
    return {
      stampLabel: "NOT COVERED",
      title: "This Act doesn't cover this conviction",
      citation: null,
      color: T.rust,
      soft: T.rustSoft,
      Icon: FileX,
      body: "Section 5 only covers use or possession convictions, and dealing convictions based on a presumption. A dealing conviction proven with direct evidence falls outside its scope.",
      next: "A community advice office or attorney can tell you whether any other relief applies to your record.",
    };
  }
  if (offence === "childdiversion") {
    return {
      stampLabel: "APPLICATION REQUIRED",
      title: "You can apply to have this record expunged",
      citation: citationFor(offence, basis),
      color: T.gold,
      soft: T.goldSoft,
      Icon: FileClock,
      body: "A diversion record from being dealt with as a child under the Child Justice Act — for using, possessing, cultivating, or dealing in cannabis — can be expunged under section 5(2)(d). This is separate from the automatic and presumption pathways, and is not a criminal conviction.",
      next: "This application goes to the Director-General: Social Development, not the Director-General: Justice and Constitutional Development. A community advice office or Legal Aid SA can help confirm the right office and form.",
    };
  }
  return {
    stampLabel: "UNCLEAR",
    title: "We can't tell from this alone",
    citation: null,
    color: T.inkSoft,
    soft: "#ECEAE3",
    Icon: HelpCircle,
    body: "Whether your conviction rested on a presumption of dealing usually has to be confirmed against the actual court record.",
    next: "A community advice office, Legal Aid SA, or the SAPS Criminal Record Centre can check your record and tell you which part of section 5 applies.",
  };
}

